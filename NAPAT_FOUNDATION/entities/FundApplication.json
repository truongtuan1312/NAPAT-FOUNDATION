{
  "name": "FundApplication",
  "type": "object",
  "properties": {
    "applicant_name": {
      "type": "string"
    },
    "email": {
      "type": "string",
      "format": "email"
    },
    "organization": {
      "type": "string"
    },
    "project_title": {
      "type": "string"
    },
    "project_description": {
      "type": "string"
    },
    "fund_type": {
      "type": "string",
      "enum": [
        "community_service",
        "research_development",
        "artistic_therapy",
        "education_technology"
      ],
      "description": "Type of funding sought"
    },
    "amount_requested": {
      "type": "number"
    },
    "project_duration": {
      "type": "string"
    },
    "alignment_statement": {
      "type": "string",
      "description": "How does this align with NAPAT's mission?"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "under_review",
        "approved",
        "declined"
      ],
      "default": "pending"
    },
    "agreed_to_terms": {
      "type": "boolean"
    }
  },
  "required": [
    "applicant_name",
    "email",
    "project_title",
    "project_description",
    "fund_type",
    "alignment_statement",
    "agreed_to_terms"
  ]
}