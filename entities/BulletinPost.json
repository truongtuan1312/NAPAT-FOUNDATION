{
  "name": "BulletinPost",
  "type": "object",
  "properties": {
    "author_name": {
      "type": "string"
    },
    "author_email": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "content": {
      "type": "string"
    },
    "category": {
      "type": "string",
      "enum": [
        "announcement",
        "question",
        "collaboration",
        "resource",
        "event"
      ],
      "default": "announcement"
    },
    "pinned": {
      "type": "boolean",
      "default": false
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "approved",
        "rejected"
      ],
      "default": "pending"
    }
  },
  "required": [
    "author_name",
    "title",
    "content"
  ]
}